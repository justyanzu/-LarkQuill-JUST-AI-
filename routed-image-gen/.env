# --- OpenAI (GPT-Image-2, premium route) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-2

# --- Volcengine Ark (Seedream lite, default route) ---
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-lite

# --- DeepSeek vision critic (multimodal review) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_VISION_MODEL=deepseek-v4-pro

# --- Service behavior ---
IMAGE_GEN_OUTPUT_DIR=./generated-images
IMAGE_GEN_MAX_ITERATIONS=3
IMAGE_GEN_HTTP_TIMEOUT_SEC=180

# --- Custom image endpoint (relay/transit) ---
OPENAI_IMAGE_ENDPOINT=https://grsai.dakka.com.cn/v1/api/generate
